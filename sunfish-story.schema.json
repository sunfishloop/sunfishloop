{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sunfishloop.com/schemas/story/0.1.json",
  "title": "Sunfish Story Manifest 0.1",
  "description": "A safe, declarative format for turning an observable agent run into an interactive story.",
  "type": "object",
  "required": ["spec_version", "id", "run", "story", "presentation"],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "const": "sunfish.story/0.1" },
    "id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "visibility": { "enum": ["private", "unlisted", "public"], "default": "private" },
    "run": { "$ref": "#/$defs/run" },
    "story": { "$ref": "#/$defs/story" },
    "presentation": { "$ref": "#/$defs/presentation" },
    "evidence": {
      "type": "array",
      "maxItems": 40,
      "items": { "$ref": "#/$defs/evidence" },
      "default": []
    },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "maxLength": 160 },
        "name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "kind": { "type": "string", "maxLength": 120 },
        "runtime": { "type": "string", "maxLength": 120 },
        "model": { "type": "string", "maxLength": 120 },
        "tools": {
          "type": "array",
          "maxItems": 24,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 },
        "token_count": { "type": ["integer", "null"], "minimum": 0 },
        "cost_usd": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "run": {
      "type": "object",
      "required": ["agent", "goal", "status"],
      "additionalProperties": false,
      "properties": {
        "source_run_id": { "type": "string", "maxLength": 160 },
        "source_format": { "enum": ["sunfish", "otlp", "langfuse", "openai", "anthropic", "custom"] },
        "trace_id": { "type": "string", "maxLength": 160 },
        "agent": { "$ref": "#/$defs/agent" },
        "goal": { "type": "string", "minLength": 1, "maxLength": 500 },
        "outcome": { "type": "string", "maxLength": 800 },
        "status": { "enum": ["succeeded", "failed", "partial", "running"] },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "metrics": { "$ref": "#/$defs/metrics" }
      }
    },
    "scene": {
      "type": "object",
      "required": ["id", "role", "title", "summary"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 100 },
        "role": { "enum": ["setup", "conflict", "turn", "move", "proof", "payoff"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "decision_source": { "enum": ["agent_reported", "trace_summary", "human_authored"] },
        "occurred_at": { "type": "string", "format": "date-time" },
        "evidence_ids": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        },
        "visual": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "layout": { "enum": ["signal-field", "split-proof", "terminal-focus", "comparison", "timeline", "quote"] },
            "camera": { "enum": ["static", "slow-push", "track", "reveal", "cut"] },
            "emphasis": { "enum": ["quiet", "normal", "high"] }
          }
        },
        "media": { "$ref": "#/$defs/scene_media" },
        "interactions": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "object",
            "required": ["region", "action", "content"],
            "additionalProperties": false,
            "properties": {
              "region": { "enum": ["origin", "judgment", "proof", "consequence"] },
              "action": { "enum": ["reveal", "expand", "compare", "focus"] },
              "label": { "type": "string", "maxLength": 48 },
              "content": { "type": "string", "maxLength": 500 },
              "evidence_id": { "type": "string", "maxLength": 100 }
            }
          }
        }
      }
    },
    "scene_media": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "image": { "$ref": "#/$defs/scene_image" },
        "audio": { "$ref": "#/$defs/scene_audio" }
      }
    },
    "scene_image": {
      "type": "object",
      "required": ["src", "alt", "bytes"],
      "additionalProperties": false,
      "properties": {
        "src": { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": "^(https?://|/)" },
        "alt": { "type": "string", "minLength": 1, "maxLength": 240 },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 2097152 },
        "fit": { "enum": ["cover", "contain"] },
        "position": { "type": "string", "maxLength": 40, "pattern": "^(center|top|bottom|left|right|[0-9]{1,3}% [0-9]{1,3}%)$" },
        "opacity": { "type": "number", "minimum": 0.1, "maximum": 1 },
        "treatment": { "enum": ["natural", "cinematic", "monochrome", "soft"] }
      }
    },
    "scene_audio": {
      "type": "object",
      "required": ["src", "label", "bytes"],
      "additionalProperties": false,
      "properties": {
        "src": { "type": "string", "minLength": 1, "maxLength": 2000, "pattern": "^(https?://|/)" },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 5242880 },
        "kind": { "enum": ["narration", "ambient", "effect"] },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "loop": { "type": "boolean" },
        "fade_in_ms": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "fade_out_ms": { "type": "integer", "minimum": 0, "maximum": 10000 }
      }
    },
    "story": {
      "type": "object",
      "required": ["title", "hook", "scenes"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "hook": { "type": "string", "minLength": 1, "maxLength": 240 },
        "scenes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 120,
          "items": { "$ref": "#/$defs/scene" }
        }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "surface": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "ink": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "muted": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "font": { "enum": ["system", "editorial", "technical", "mono"] }
      }
    },
    "presentation": {
      "type": "object",
      "required": ["preset"],
      "additionalProperties": false,
      "properties": {
        "preset": { "enum": ["cinematic", "briefing", "investigation"] },
        "viewer_can_switch": { "type": "boolean", "default": false },
        "available_presets": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["cinematic", "briefing", "investigation"] }
        },
        "theme": { "$ref": "#/$defs/theme" },
        "motion": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pace": { "enum": ["slow", "measured", "fast"] },
            "transition": { "enum": ["dissolve", "cut", "slide", "signal"] },
            "intensity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["id", "type", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 100 },
        "type": { "enum": ["screenshot", "diff", "test_report", "log_excerpt", "link", "file_hash"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 160 },
        "uri": { "type": "string", "maxLength": 2000 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "mime_type": { "type": "string", "maxLength": 120 }
      },
      "anyOf": [{ "required": ["uri"] }, { "required": ["sha256"] }]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trust_level": { "enum": ["verified", "instrumented", "remote", "self_reported"] },
        "raw_trace_policy": { "const": "local_only" },
        "owner_approved": { "type": "boolean" }
      }
    }
  }
}
